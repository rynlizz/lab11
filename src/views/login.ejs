<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login</title>
  <style>
    :root{
      --bg1:#eaf6ff;
      --bg2:#f7fbff;
      --card:rgba(255,255,255,.78);
      --stroke:rgba(8, 61, 119, .12);
      --text:#0b2545;
      --muted:rgba(11,37,69,.7);
      --primary:#3aa0ff;
      --primary2:#6bd6ff;
      --danger:#ff4d6d;
      --shadow: 0 18px 60px rgba(11,37,69,.14);
      --radius:18px;
      --focus: 0 0 0 4px rgba(58,160,255,.22);
      --font: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial;
    }
    *{ box-sizing:border-box; }
    body{
      margin:0;
      font-family:var(--font);
      color:var(--text);
      min-height:100vh;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:28px;
      background:
        radial-gradient(1100px 560px at 20% 15%, rgba(107,214,255,.55), transparent 60%),
        radial-gradient(820px 480px at 80% 35%, rgba(58,160,255,.35), transparent 55%),
        linear-gradient(180deg, var(--bg1), var(--bg2));
    }
    .snow::before{
      content:"";
      position:fixed;
      inset:-40px;
      pointer-events:none;
      background-image:
        radial-gradient(circle at 10% 20%, rgba(255,255,255,.9) 0 2px, transparent 3px),
        radial-gradient(circle at 50% 30%, rgba(255,255,255,.75) 0 1.5px, transparent 3px),
        radial-gradient(circle at 80% 60%, rgba(255,255,255,.7) 0 2px, transparent 3px);
      background-size: 320px 320px, 260px 260px, 360px 360px;
      opacity:.5;
      animation: drift 16s linear infinite;
    }
    @keyframes drift{ from{transform:translateY(-26px)} to{transform:translateY(26px)} }

    .wrap{ width:min(980px, 100%); display:grid; grid-template-columns: 1fr 1fr; gap:16px; }
    @media (max-width: 880px){ .wrap{ grid-template-columns:1fr; } }

    .card{
      border:1px solid var(--stroke);
      background: var(--card);
      backdrop-filter: blur(12px);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 22px;
    }
    .top{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      margin-bottom: 10px;
    }
    .brand{ display:flex; align-items:center; gap:10px; font-weight:900; letter-spacing:.2px; }
    .dot{ width:12px;height:12px;border-radius:50%; background:linear-gradient(135deg,var(--primary),var(--primary2)); }

    h1{ margin: 6px 0 6px; font-size: 30px; letter-spacing:-.3px; }
    .sub{ margin:0 0 14px 0; color: var(--muted); line-height:1.6; }

    form{ display:grid; gap:10px; }
    .row{ display:grid; grid-template-columns: 1fr 1fr; gap:10px; }
    @media (max-width: 520px){ .row{ grid-template-columns:1fr; } }

    input{
      width:100%;
      padding: 12px 12px;
      border-radius: 14px;
      border:1px solid rgba(8,61,119,.16);
      background: rgba(255,255,255,.82);
      outline:none;
      transition: box-shadow .12s ease, border-color .12s ease;
    }
    input:focus{ box-shadow: var(--focus); border-color: rgba(58,160,255,.45); }

    .btn{
      padding: 11px 14px;
      border-radius: 14px;
      border: 0;
      cursor:pointer;
      font-weight: 850;
      letter-spacing:.1px;
      background: linear-gradient(135deg, var(--primary), var(--primary2));
      color: #fff;
      box-shadow: 0 14px 34px rgba(58,160,255,.26);
      transition: transform .12s ease, box-shadow .12s ease, filter .12s ease;
    }
    .btn:hover{ transform: translateY(-1px); box-shadow: 0 18px 44px rgba(58,160,255,.32); }
    .btn.secondary{
      background: rgba(255,255,255,.75);
      color: var(--text);
      border:1px solid rgba(58,160,255,.22);
      box-shadow:none;
    }

    .divider{
      margin: 14px 0;
      height: 1px;
      background: rgba(8,61,119,.12);
      border:0;
    }

    .alert{
      margin: 10px 0 0;
      padding: 10px 12px;
      border-radius: 14px;
      border:1px solid rgba(255,77,109,.25);
      background: rgba(255,77,109,.08);
      color: #8a1730;
      font-weight: 650;
    }

    a.link{ color: var(--text); text-decoration:none; font-weight: 750; }
    a.link:hover{ text-decoration: underline; }

    .hint{ color: var(--muted); margin: 0; line-height:1.6; }
    .mini{ font-size: 12px; color: var(--muted); margin: 0; }
  </style>
</head>

<body class="snow">
  <div class="wrap">
    <section class="card">
      <div class="top">
        <div class="brand"><span class="dot"></span> Lab11 </div>
        <a class="link" href="/">Home</a>
      </div>

      <h1>Login</h1>
      <p class="sub">Sign in to access the protected profile page.</p>

      <% if (err) { %>
        <div class="alert">
          <%= err === "missing" ? "Please enter email and password" : "Invalid email or password" %>
        </div>
      <% } %>

      <form method="POST" action="/login" style="margin-top:12px;">
        <div class="row">
          <input name="email" placeholder="Email" autocomplete="email" />
          <input name="password" type="password" placeholder="Password" autocomplete="current-password" />
        </div>
        <button class="btn" type="submit">Login</button>
      </form>

      <p class="mini" style="margin-top:10px;">JWT is stored in an httpOnly cookie.</p>
    </section>

    <section class="card">
      <div class="top">
        <div>
          <h1 style="margin:6px 0 6px;">Register</h1>
          <p class="sub">Create a test user for this lab.</p>
        </div>
      </div>

      <form method="POST" action="/register">
        <div class="row">
          <input name="email" placeholder="Email" autocomplete="email" />
          <input name="password" type="password" placeholder="Password" autocomplete="new-password" />
        </div>
        <button class="btn secondary" type="submit">Register (for testing)</button>
      </form>

      <hr class="divider" />

      <p class="hint">
        After registering, return to the Login card and sign in.
        Then open <a class="link" href="/profile">Profile</a>.
      </p>
    </section>
  </div>
</body>
</html>